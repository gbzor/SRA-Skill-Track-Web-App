# --- Database (Vercel Postgres / Neon) ---
# In Vercel dashboard: Storage → Create → Postgres. The integration sets these
# automatically. For local dev, copy the "POSTGRES_PRISMA_URL" from the dashboard.
DATABASE_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-32-bytes-base64"
# Optional: explicitly pin the URL in production. Vercel auto-provides this.
# AUTH_URL="https://your-domain.vercel.app"

# --- Upstash Redis (rate limiting) ---
# Free tier at upstash.com. If unset, rate limiting is a no-op (NOT recommended in prod).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
