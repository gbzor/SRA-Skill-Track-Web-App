generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  currentRung  Int      @default(1)
  pbToNext     Int      @default(20)
  // Bumped on password change; embedded in every issued JWT and compared on
  // each request so a stolen session token is invalidated the moment the
  // password is rotated, instead of staying valid until the 7-day JWT expiry.
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  reports      Report[]

  @@index([email])
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period    String
  pb        Int
  score     Int
  rate      Int
  colorIdx  Int
  xp        Int
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
